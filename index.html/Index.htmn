<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>QuickChat</title>
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body { font-family:system-ui; background:#1a1a2e; color:white; display:flex; justify-content:center; align-items:center; height:100vh; }
        .auth { background:#1e1e30; padding:24px; border-radius:16px; text-align:center; width:90%; max-width:400px; }
        .auth input { width:100%; padding:14px; margin:8px 0; border-radius:12px; border:none; background:#242436; color:white; font-size:16px; }
        .btn { width:100%; padding:14px; border:none; border-radius:12px; color:white; font-size:16px; font-weight:bold; cursor:pointer; margin:4px 0; }
        .purple { background:#6c5ce7; }
        .outline { background:transparent; border:2px solid #6c5ce7; color:#6c5ce7; }
    </style>
</head>
<body>
    <div class="auth" id="authScreen">
        <h1>💬</h1><h2>QuickChat</h2>
        <input type="text" id="authName" placeholder="Имя">
        <input type="text" id="authId" placeholder="ID (@username)">
        <input type="password" id="authPass" placeholder="Пароль">
        <p id="msg" style="font-size:12px;margin:8px 0;"></p>
        <button class="btn purple" onclick="login()">🔑 Войти</button>
        <button class="btn outline" onclick="register()">✨ Регистрация</button>
    </div>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-database-compat.js"></script>
    <script>
        firebase.initializeApp({
            apiKey:"AIzaSyBXK5QxcIk6GC4TCTzmHxFTr_Tf_5cQv3c",
            authDomain:"quickchat123-51148.firebaseapp.com",
            databaseURL:"https://quickchat123-51148-default-rtdb.firebaseio.com",
            projectId:"quickchat123-51148",
            storageBucket:"quickchat123-51148.firebasestorage.app",
            messagingSenderId:"662177132719",
            appId:"1:662177132719:web:3039b49bcde8987745a45a"
        });
        const db=firebase.database();
        function login(){
            const id=document.getElementById('authId').value.trim();
            const pass=document.getElementById('authPass').value.trim();
            const uid=id.startsWith('@')?id:'@'+id;
            db.ref('users/'+uid).once('value',snap=>{
                const d=snap.val();
                if(!d){document.getElementById('msg').textContent='Не найден';return;}
                if(d.pass!==pass){document.getElementById('msg').textContent='Неверный пароль';return;}
                document.getElementById('msg').textContent='✅ Вход!'; 
            });
        }
        function register(){
            const name=document.getElementById('authName').value.trim();
            const id=document.getElementById('authId').value.trim();
            const pass=document.getElementById('authPass').value.trim();
            const uid=id.startsWith('@')?id:'@'+id;
            if(!name||!id||!pass){document.getElementById('msg').textContent='Заполни все поля';return;}
            db.ref('users/'+uid).once('value',snap=>{
                if(snap.val()){document.getElementById('msg').textContent='ID занят!';return;}
                db.ref('users/'+uid).set({name,pass,online:true,coins:0,gifts:{}});
                document.getElementById('msg').textContent='✅ Создан!';
            });
        }
    </script>
</body>
</html>
